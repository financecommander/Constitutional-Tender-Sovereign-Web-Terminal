# Constitutional Tender — Environment Variables
# Copy this to apps/api/.env and fill in real values

# Database
DATABASE_URL="postgresql://ctuser:CHANGE_ME_IN_PRODUCTION@localhost:5432/constitutional_tender"

# Auth0
AUTH0_DOMAIN="your-tenant.us.auth0.com"
AUTH0_AUDIENCE="https://api.constitutionaltender.com"
AUTH0_CLIENT_ID="your-client-id"

# Frontend (also set in apps/web/.env.local)
NEXT_PUBLIC_API_URL="http://YOUR_VM_IP:4000"
NEXT_PUBLIC_AUTH0_DOMAIN="your-tenant.us.auth0.com"
NEXT_PUBLIC_AUTH0_CLIENT_ID="your-client-id"
NEXT_PUBLIC_AUTH0_AUDIENCE="https://api.constitutionaltender.com"
NEXT_PUBLIC_AUTH0_REDIRECT_URI="http://YOUR_VM_IP"

# Server
PORT=4000
NODE_ENV=production
