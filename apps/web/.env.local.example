# Auth0 Configuration
# Get these values from your Auth0 Dashboard (https://manage.auth0.com)

# Your Auth0 domain (e.g., dev-abc123.us.auth0.com)
NEXT_PUBLIC_AUTH0_DOMAIN=your-domain.auth0.com

# Your Auth0 application client ID
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-client-id

# Your API identifier/audience (configured in Auth0 API settings)
NEXT_PUBLIC_AUTH0_AUDIENCE=https://your-api-identifier.com

# Backend API URL (defaults to http://localhost:4000 if not set)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Payment Processing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
