# Auth0 Configuration
# Get these values from your Auth0 Dashboard
AUTH0_ISSUER_URL=https://your-domain.auth0.com/
AUTH0_AUDIENCE=https://your-api-identifier.com

# Optional: Custom namespace for Auth0 custom claims (e.g., https://your-app.com)
# Leave empty if using standard claims
AUTH0_CUSTOM_NAMESPACE=

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/constitutional_tender

# Server Configuration
PORT=4000
NODE_ENV=development

# CORS Configuration (for production)
FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Plaid
PLAID_CLIENT_ID=...
PLAID_SECRET=...
PLAID_ENV=sandbox

# Coinbase Commerce
COINBASE_COMMERCE_API_KEY=...
COINBASE_COMMERCE_WEBHOOK_SECRET=...

# Nymbus (Wire Transfer)
NYMBUS_API_URL=https://api.nymbus.com
NYMBUS_API_KEY=...
NYMBUS_ACCOUNT_ID=...

# Redis
REDIS_URL=redis://localhost:6379
