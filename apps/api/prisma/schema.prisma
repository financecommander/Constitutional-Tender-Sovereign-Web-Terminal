generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ───────────────────────────────────────────────────

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum Currency {
  USD
  EUR
  CHF
  SGD
  KYD
  GBP
}

enum TransactionType {
  BUY
  SELL
  TELEPORT
  WITHDRAWAL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum Metal {
  XAU
  XAG
  XPT
  XPD
}

enum ProductCategory {
  COIN
  BAR
  ROUND
}

enum DeliveryType {
  DIRECT_SHIP
  VAULT_ALLOCATE
}

enum PaymentRail {
  WIRE
  ACH
  CRYPTO
}

enum OrderStatus {
  PRICE_LOCKED
  FUNDS_CONFIRMED
  SUPPLIER_CONFIRMED
  SHIPMENT_CREATED
  IN_TRANSIT
  DELIVERED
  VAULT_ALLOCATED
  CANCELLED
}

// ── Existing Models ─────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  authId       String    @unique @map("auth_id")
  email        String    @unique
  fullName     String    @map("full_name")
  kycStatus    KycStatus @default(PENDING) @map("kyc_status")
  baseCurrency Currency  @default(USD) @map("base_currency")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  holdings     Holding[]
  transactions Transaction[]
  quotes       Quote[]
  orders       Order[]

  @@map("users")
}

model Vault {
  id                    String   @id @default(uuid())
  name                  String
  location              String
  country               String
  regulatoryJurisdiction String  @map("regulatory_jurisdiction")
  supportedAssets       String[] @map("supported_assets")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  holdings         Holding[]
  transactionsFrom Transaction[] @relation("TransactionFromVault")
  transactionsTo   Transaction[] @relation("TransactionToVault")

  @@map("vaults")
}

model Asset {
  id             String   @id @default(uuid())
  name           String
  symbol         String   @unique
  metalType      String   @map("metal_type")
  weightOz       Decimal  @map("weight_oz")
  livePriceBid   Decimal  @default(0) @map("live_price_bid")
  livePriceAsk   Decimal  @default(0) @map("live_price_ask")
  spreadPercent  Decimal  @default(0) @map("spread_percent")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  holdings     Holding[]
  transactions Transaction[]

  @@map("assets")
}

model Holding {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  assetId   String   @map("asset_id")
  vaultId   String   @map("vault_id")
  quantity  Decimal
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id])
  asset Asset @relation(fields: [assetId], references: [id])
  vault Vault @relation(fields: [vaultId], references: [id])

  @@unique([userId, assetId, vaultId])
  @@index([userId])
  @@index([assetId])
  @@map("holdings")
}

model Transaction {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  assetId         String            @map("asset_id")
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  quantity        Decimal
  pricePerUnit    Decimal           @map("price_per_unit")
  totalAmount     Decimal           @map("total_amount")
  currency        Currency          @default(USD)
  fromVaultId     String?           @map("from_vault_id")
  toVaultId       String?           @map("to_vault_id")
  fxRate          Decimal?          @map("fx_rate")
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  user      User   @relation(fields: [userId], references: [id])
  asset     Asset  @relation(fields: [assetId], references: [id])
  fromVault Vault? @relation("TransactionFromVault", fields: [fromVaultId], references: [id])
  toVault   Vault? @relation("TransactionToVault", fields: [toVaultId], references: [id])

  @@index([userId])
  @@index([assetId])
  @@index([status])
  @@map("transactions")
}

// ── New Models (v2) ─────────────────────────────────────────

model MetalSpot {
  id           String   @id @default(uuid())
  metal        Metal
  spotUsdPerOz Decimal  @map("spot_usd_per_oz")
  changePct24h Decimal  @default(0) @map("change_pct_24h")
  source       String   @default("manual")
  asOf         DateTime @map("as_of")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([metal, asOf])
  @@index([metal])
  @@map("metal_spots")
}

model ProductSku {
  id                   String          @id @default(uuid())
  sku                  String          @unique
  metal                Metal
  name                 String
  weightOz             Decimal         @map("weight_oz")
  purity               Decimal         @default(0.9999)
  category             ProductCategory @default(COIN)
  images               String[]
  eligibleDeliveryTypes DeliveryType[] @map("eligible_delivery_types")
  flags                String[]
  isActive             Boolean         @default(true) @map("is_active")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  offers SupplierOffer[]
  quotes Quote[]

  @@index([metal])
  @@map("product_skus")
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  contact   String?
  website   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  offers SupplierOffer[]

  @@map("suppliers")
}

model SupplierOffer {
  id           String   @id @default(uuid())
  productSkuId String   @map("product_sku_id")
  supplierId   String   @map("supplier_id")
  availableQty Int      @map("available_qty")
  shipEtaDays  Int      @map("ship_eta_days")
  shipOrigin   String   @map("ship_origin")
  premiumUsd   Decimal  @map("premium_usd")
  constraints  String[]
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  productSku ProductSku @relation(fields: [productSkuId], references: [id])
  supplier   Supplier   @relation(fields: [supplierId], references: [id])
  quotes     Quote[]

  @@index([productSkuId])
  @@index([supplierId])
  @@map("supplier_offers")
}

model Quote {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  productSkuId   String       @map("product_sku_id")
  offerId        String       @map("offer_id")
  quantity       Int
  lockedSpot     Decimal      @map("locked_spot")
  lockedPremium  Decimal      @map("locked_premium")
  lockedSpread   Decimal      @map("locked_spread")
  lockedShipping Decimal      @map("locked_shipping")
  totalUsd       Decimal      @map("total_usd")
  deliveryType   DeliveryType @map("delivery_type")
  expiresAt      DateTime     @map("expires_at")
  isUsed         Boolean      @default(false) @map("is_used")
  createdAt      DateTime     @default(now()) @map("created_at")

  user       User          @relation(fields: [userId], references: [id])
  productSku ProductSku    @relation(fields: [productSkuId], references: [id])
  offer      SupplierOffer @relation(fields: [offerId], references: [id])
  order      Order?

  @@index([userId])
  @@index([expiresAt])
  @@map("quotes")
}

model Order {
  id           String       @id @default(uuid())
  quoteId      String       @unique @map("quote_id")
  userId       String       @map("user_id")
  status       OrderStatus  @default(PRICE_LOCKED)
  deliveryType DeliveryType @map("delivery_type")
  paymentRail  PaymentRail  @map("payment_rail")
  shipName     String?      @map("ship_name")
  shipAddress  String?      @map("ship_address")
  shipCity     String?      @map("ship_city")
  shipState    String?      @map("ship_state")
  shipZip      String?      @map("ship_zip")
  shipCountry  String?      @map("ship_country")
  receiptSpot     Decimal   @map("receipt_spot")
  receiptPremium  Decimal   @map("receipt_premium")
  receiptSpread   Decimal   @map("receipt_spread")
  receiptShipping Decimal   @map("receipt_shipping")
  receiptTotal    Decimal   @map("receipt_total")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  quote  Quote        @relation(fields: [quoteId], references: [id])
  user   User         @relation(fields: [userId], references: [id])
  events OrderEvent[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderEvent {
  id        String      @id @default(uuid())
  orderId   String      @map("order_id")
  stage     OrderStatus
  note      String?
  createdAt DateTime    @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_events")
}
