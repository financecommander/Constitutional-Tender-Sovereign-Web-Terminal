generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum Currency {
  USD
  EUR
  CHF
  SGD
  KYD
  GBP
}

enum TransactionType {
  BUY
  SELL
  TELEPORT
  WITHDRAWAL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  WIRE_TRANSFER
  ACH
  CRYPTO
  CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

enum CryptoNetwork {
  BITCOIN
  ETHEREUM
  USDT_ERC20
  USDT_TRC20
  USDC_ERC20
  LITECOIN
  RIPPLE
}

model User {
  id           String    @id @default(uuid())
  authId       String    @unique @map("auth_id")
  email        String    @unique
  fullName     String    @map("full_name")
  kycStatus    KycStatus @default(PENDING) @map("kyc_status")
  baseCurrency Currency  @default(USD) @map("base_currency")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  holdings       Holding[]
  transactions   Transaction[]
  bankAccounts   BankAccount[]
  wireTransfers  WireTransfer[]
  cryptoPayments CryptoPayment[]

  @@map("users")
}

model Vault {
  id                     String   @id @default(uuid())
  name                   String
  location               String
  country                String
  regulatoryJurisdiction String   @map("regulatory_jurisdiction")
  supportedAssets        String[] @map("supported_assets")
  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  holdings         Holding[]
  transactionsFrom Transaction[] @relation("TransactionFromVault")
  transactionsTo   Transaction[] @relation("TransactionToVault")

  @@map("vaults")
}

model Asset {
  id            String   @id @default(uuid())
  name          String
  symbol        String   @unique
  metalType     String   @map("metal_type")
  weightOz      Decimal  @map("weight_oz")
  livePriceBid  Decimal  @default(0) @map("live_price_bid")
  livePriceAsk  Decimal  @default(0) @map("live_price_ask")
  spreadPercent Decimal  @default(0) @map("spread_percent")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  holdings     Holding[]
  transactions Transaction[]

  @@map("assets")
}

model Holding {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  assetId   String   @map("asset_id")
  vaultId   String   @map("vault_id")
  quantity  Decimal
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id])
  asset Asset @relation(fields: [assetId], references: [id])
  vault Vault @relation(fields: [vaultId], references: [id])

  @@unique([userId, assetId, vaultId])
  @@map("holdings")
}

model Transaction {
  id           String            @id @default(uuid())
  userId       String            @map("user_id")
  assetId      String            @map("asset_id")
  type         TransactionType
  status       TransactionStatus @default(PENDING)
  quantity     Decimal
  pricePerUnit Decimal           @map("price_per_unit")
  totalAmount  Decimal           @map("total_amount")
  currency     Currency          @default(USD)
  fromVaultId  String?           @map("from_vault_id")
  toVaultId    String?           @map("to_vault_id")
  fxRate       Decimal?          @map("fx_rate")
  notes        String?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  user      User   @relation(fields: [userId], references: [id])
  asset     Asset  @relation(fields: [assetId], references: [id])
  fromVault Vault? @relation("TransactionFromVault", fields: [fromVaultId], references: [id])
  toVault   Vault? @relation("TransactionToVault", fields: [toVaultId], references: [id])

  @@map("transactions")
}

model BankAccount {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  bankName          String   @map("bank_name")
  accountHolderName String   @map("account_holder_name")
  accountNumber     String   @map("account_number")
  routingNumber     String   @map("routing_number")
  accountType       String   @map("account_type") // CHECKING, SAVINGS
  swiftCode         String?  @map("swift_code")
  iban              String?
  isVerified        Boolean  @default(false) @map("is_verified")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id])
  wireTransfers WireTransfer[]

  @@map("bank_accounts")
}

model WireTransfer {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  bankAccountId   String        @map("bank_account_id")
  paymentMethod   PaymentMethod @default(WIRE_TRANSFER) @map("payment_method")
  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  amount          Decimal
  currency        Currency      @default(USD)
  referenceNumber String?       @map("reference_number")
  beneficiaryName String        @map("beneficiary_name")
  beneficiaryBank String        @map("beneficiary_bank")
  purpose         String?
  notes           String?
  processedAt     DateTime?     @map("processed_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id])
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@map("wire_transfers")
}

model CryptoPayment {
  id                    String        @id @default(uuid())
  userId                String        @map("user_id")
  network               CryptoNetwork
  paymentStatus         PaymentStatus @default(PENDING) @map("payment_status")
  amount                Decimal
  cryptoCurrency        String        @map("crypto_currency") // BTC, ETH, USDT, etc.
  walletAddress         String        @map("wallet_address")
  transactionHash       String?       @map("transaction_hash")
  confirmations         Int           @default(0)
  requiredConfirmations Int           @default(6) @map("required_confirmations")
  fiatAmount            Decimal?      @map("fiat_amount")
  fiatCurrency          Currency?     @map("fiat_currency")
  exchangeRate          Decimal?      @map("exchange_rate")
  notes                 String?
  processedAt           DateTime?     @map("processed_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("crypto_payments")
}
